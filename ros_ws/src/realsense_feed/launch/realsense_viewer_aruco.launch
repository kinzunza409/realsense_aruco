<launch>
    <include file="$(find realsense2_camera)/launch/rs_camera.launch"/>
        <arg name="color_width" value="1920"/>
        <arg name="color_height" value="1080"/>
    <node name="realsense_aruco_pose" pkg="realsense_feed" type="aruco_pose.py" output="screen"/>
    <node pkg="tf2_ros" type="static_transform_publisher" name="camera_broadcaster" args="1 0 0 0 0 0 1 world camera" />
</launch>